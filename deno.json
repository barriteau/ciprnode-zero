{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --watch=src/,public/ main.js",
    "front-dev": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --watch=src/,public/ main.js --front-only",
    "debug": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --watch=src/,public/ main.js --debug",
    "start": "clear & deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi main.js",
    "stop": "deno run --allow-net --allow-read --allow-write --allow-env scripts/core/cli_control.js stop",
    "restart": "deno task stop && deno task start",
    "test": "deno test --allow-read --allow-none",
    "build": "deno run --allow-run --allow-read --allow-write --allow-env scripts/maintenance/build.js"
  },
  "imports": {
    "@eta-dev/eta": "jsr:@eta-dev/eta@^3.5.0",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/http": "jsr:@std/http@^1.0.24",
    "@std/encoding": "jsr:@std/encoding@^1.0.0",
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.2"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve"
  }
}
