<footer aria-label="<%= it.t('footer.label') %>">
  <span>
    <a href="http://cipr.info"><%= it.t('footer.get_indexed') %></a>
  </span>

  <!--
  <span>
    <a href="/profiles/cipr.json"><%= it.t('footer.profile') %></a>
  </span>

  <span>
    <a href="https://codeberg.org/Ciprnode-zero">Codeberg (<%= it.t('footer.source_code') %>)</a>
  </span>
  -->

  <span>
    <a href="#" id="pwa-install-btn" class="hidden" data-ios-msg="<%= it.t('footer.install_ios') %>" data-fallback-msg="<%= it.t('footer.install_fallback') %>">
      <span class="desktop-only">
        <%= it.t('footer.install_desktop') %> <b class="svg-icon install-desktop inline" aria-hidden="true"></b>
      </span>
      <span class="mobile-only">
        <%= it.t('footer.install_mobile') %> <b class="svg-icon install-mobile inline" aria-hidden="true"></b>
      </span>
    </a>
  </span>

  <span>
    <a href="https://juan.barriteau.net/LPA/" rel="license" title="Licencia publica apodistintiva">
      <b class="svg-icon lpa inline"></b>
      2026
    </a>
    <a id="to-author-footer" href="https://juan.barriteau.net/" rel="author" title="Juan Barriteau">
      <strong>Juan Barriteau</strong>
    </a>
  </span>

</footer>
