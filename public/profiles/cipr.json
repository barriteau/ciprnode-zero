{
  "$schema": "https://alps-io.github.io/schemas/alps.json",
  "alps": {
    "version": "1.0",
    "title": "CiprAPI Profile",
    "doc": {
      "value": "Application-Level Profile Semantics for the Cosmic Index of Public Resources (Cipr) API."
    },
    "descriptor": [
      {
        "id": "za",
        "type": "semantic",
        "title": "Zone Apex",
        "doc": { "value": "The unique identifier for the resource (DNS Zone Apex)." },
        "def": "https://schema.org/identifier"
      },
      {
        "id": "title",
        "type": "semantic",
        "title": "Title",
        "doc": { "value": "The resource title." },
        "def": "https://schema.org/name"
      },
      {
        "id": "description",
        "type": "semantic",
        "title": "Description",
        "doc": { "value": "A brief explanation of the resource." },
        "def": "https://schema.org/description"
      },
      {
        "id": "keywords",
        "type": "semantic",
        "title": "Keywords",
        "doc": { "value": "Space-separated tags." },
        "def": "https://schema.org/keywords"
      },
      {
        "id": "ol",
        "type": "semantic",
        "title": "Offensiveness Level",
        "doc": { "value": "Subjective rating of content (0=Safe, 1=Individual, 2=Collective, 3=Universal)." }
      },
      {
        "id": "latitude",
        "type": "semantic",
        "title": "Latitude",
        "doc": { "value": "Geographic latitude * 10,000,000." },
        "def": "https://schema.org/latitude"
      },
      {
        "id": "longitude",
        "type": "semantic",
        "title": "Longitude",
        "doc": { "value": "Geographic longitude * 10,000,000." },
        "def": "https://schema.org/longitude"
      },
      {
        "id": "timestamp",
        "type": "semantic",
        "title": "Timestamp",
        "doc": { "value": "Unix Epoch of last update." },
        "def": "https://schema.org/dateModified"
      },
      {
        "id": "primary_lang",
        "type": "semantic",
        "title": "Primary Language",
        "doc": { "value": "The primary language code (e.g. ISO 639-1) for the resource." },
        "def": "https://schema.org/inLanguage"
      },
      {
        "id": "geo_latitude",
        "type": "semantic",
        "title": "Geographic Latitude Filter",
        "doc": { "value": "Latitude center point for geographic search queries." }
      },
      {
        "id": "geo_longitude",
        "type": "semantic",
        "title": "Geographic Longitude Filter",
        "doc": { "value": "Longitude center point for geographic search queries." }
      },
      {
        "id": "geo_min_radius_km",
        "type": "semantic",
        "title": "Minimum Radius (km)",
        "doc": { "value": "Minimum geographic radius for search in kilometers." }
      },
      {
        "id": "geo_max_radius_km",
        "type": "semantic",
        "title": "Maximum Radius (km)",
        "doc": { "value": "Maximum geographic radius for search in kilometers." }
      },
      {
        "id": "before",
        "type": "semantic",
        "title": "Before Timestamp",
        "doc": { "value": "Filter results updated before this Unix Epoch timestamp." }
      },
      {
        "id": "after",
        "type": "semantic",
        "title": "After Timestamp",
        "doc": { "value": "Filter results updated after this Unix Epoch timestamp." }
      },
      {
        "id": "pages_num",
        "type": "semantic",
        "title": "Page Numbers",
        "doc": { "value": "Array of page numbers or ranges to retrieve." }
      },
      {
        "id": "pages_size",
        "type": "semantic",
        "title": "Page Sizes",
        "doc": { "value": "Array of number of entries per page." }
      },
      {
        "id": "CiprResource",
        "type": "semantic",
        "title": "Cipr Resource",
        "descriptor": [
          { "href": "#za" },
          { "href": "#title" },
          { "href": "#description" },
          { "href": "#keywords" },
          { "href": "#primary_lang" },
          { "href": "#ol" },
          { "href": "#latitude" },
          { "href": "#longitude" },
          { "href": "#timestamp" },
          { "href": "#goEntry" },
          { "href": "#doUpdateEntry" },
          { "href": "#doDeleteEntry" }
        ]
      },
      {
        "id": "CiprCollection",
        "type": "semantic",
        "title": "Cipr Collection",
        "descriptor": [
          { "href": "#CiprResource" },
          { "href": "#doSearch" }
        ]
      },
      {
        "id": "goEntry",
        "type": "safe",
        "rt": "#CiprResource",
        "title": "View Entry",
        "descriptor": [ { "href": "#za" } ]
      },
      {
        "id": "doUpdateEntry",
        "type": "idempotent",
        "rt": "#CiprResource",
        "title": "Update/Register Entry",
        "descriptor": [ { "href": "#CiprResource" } ]
      },
      {
        "id": "doDeleteEntry",
        "type": "idempotent",
        "rt": "#CiprCollection",
        "title": "Delete Entry",
        "descriptor": [ { "href": "#za" } ]
      },
      {
        "id": "doSearch",
        "type": "safe",
        "rt": "#CiprCollection",
        "title": "Search",
        "descriptor": [
           { "id": "query", "type": "semantic", "doc": { "value": "FTS Expression" } },
           { "href": "#ol" },
           { "href": "#primary_lang" },
           { "href": "#geo_latitude" },
           { "href": "#geo_longitude" },
           { "href": "#geo_min_radius_km" },
           { "href": "#geo_max_radius_km" },
           { "href": "#before" },
           { "href": "#after" },
           { "href": "#pages_num" },
           { "href": "#pages_size" }
        ]
      }
    ]
  }
}
